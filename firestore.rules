rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Só quem estiver autenticado (a conta compartilhada do casal) pode ler/gravar.
    // Como o app usa um único documento (wedding/state), isso já protege os dados.
    match /wedding/{doc} {
      allow read, write: if request.auth != null;
    }
    // Bloqueia qualquer outra coleção por padrão.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
